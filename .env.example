# Preferred: "Publish to web" CSV link from Google Sheets
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vTaYjCK38g8xguJHyotCOFU7X0ZuoWQwX9el9jdq7GhGBj2YIcTm62qu1kEGdsYNNxKwBwVOBXlz8pe/pub?output=csv

# Alternative: sheet ID from the edit URL (uses export API instead)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=0

# Optional: for private sheets, paste the full service account JSON on one line
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional: sheet range when using a service account (defaults to Sheet1)
GOOGLE_SHEET_RANGE=Sheet1
