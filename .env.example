# --- items tab (product table) ---
GOOGLE_SHEET_ITEMS_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vTaYjCK38g8xguJHyotCOFU7X0ZuoWQwX9el9jdq7GhGBj2YIcTm62qu1kEGdsYNNxKwBwVOBXlz8pe/pub?gid=0&single=true&output=csv

# --- static tab (key/value branding & image URLs) ---
GOOGLE_SHEET_STATIC_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vTaYjCK38g8xguJHyotCOFU7X0ZuoWQwX9el9jdq7GhGBj2YIcTm62qu1kEGdsYNNxKwBwVOBXlz8pe/pub?gid=1239078304&single=true&output=csv

# Static sheet format (row 1 = headers):
# | key          | value                              |
# | site_title   | Legends Memorabilia                |
# | tagline      | Curated authenticated memorabilia  |
# | logo         | https://...                        |
# | address      | 123 Main St, City                  |
# | phone        | +1 555 0100                        |
# | email        | hello@example.com                  |
# | hours        | Mon-Fri 10am-6pm                   |
# | about_title  | About the collection               |
# | about_intro  | Short intro for about page         |
# | about_body   | Longer about copy (supports \n)    |
# | footer_tagline | Footer blurb                     |
#
# Items sheet columns:
# | name | price | category | description | images | hero | auction |
# images = comma-separated URLs; hero=yes for featured auction pieces (no price shown)

# Alternative: sheet ID + tab gid from the URL when switching tabs (?gid=...)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_ITEMS_GID=0
GOOGLE_SHEET_STATIC_GID=

# Optional: service account for private sheets
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ITEMS_RANGE=items
GOOGLE_SHEET_STATIC_RANGE=static
